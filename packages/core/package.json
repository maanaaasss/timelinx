{
  "name": "@timelinx/core",
  "version": "1.0.0-beta.3",
  "description": "Headless TypeScript engine for professional NLE timeline editing. Framework-agnostic, fully tested.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./serialization": {
      "types": "./dist/serialization.d.ts",
      "import": "./dist/serialization.js",
      "require": "./dist/serialization.cjs"
    },
    "./media": {
      "types": "./dist/media.d.ts",
      "import": "./dist/media.js",
      "require": "./dist/media.cjs"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "require": "./dist/internal.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup src/index.ts src/serialization.ts src/media.ts src/internal.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/serialization.ts src/media.ts src/internal.ts --format cjs,esm --dts --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:legacy": "tsx src/__tests__/edge-case-tests.ts && tsx src/__tests__/stress-tests.ts && tsx src/__tests__/phase2-tests.ts"
  },
  "keywords": [
    "timeline",
    "nle",
    "video-editor",
    "typescript",
    "headless",
    "editing"
  ],
  "author": "Timeline Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/maanaaasss/timelinx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maanaaasss/timelinx",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/maanaaasss/timelinx/blob/main/packages/core/README.md",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^24.10.11",
    "@vitest/coverage-v8": "^2.1.8",
    "fast-check": "^4.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8"
  }
}
