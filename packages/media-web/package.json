{
  "name": "@timelinx/media-web",
  "version": "1.0.0-beta.2",
  "private": true,
  "description": "Web-native media adapters for @timelinx/core — WebCodecs, WebAudio, thumbnails, export",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./workers": {
      "import": "./dist/workers/index.js",
      "require": "./dist/workers/index.cjs",
      "types": "./dist/workers/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@timelinx/core": ">=1.0.0-beta.2"
  },
  "devDependencies": {
    "@timelinx/core": "workspace:*",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "license": "MIT"
}
