{
  "name": "@webpacked-timeline/ui",
  "version": "1.0.0-beta.1",
  "description": "DaVinci-style React timeline UI. Drop-in components built on @webpacked-timeline/core and @webpacked-timeline/react.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles/structure": "./dist/structure.css",
    "./styles/tokens": "./dist/tokens.css",
    "./styles/presets/dark-pro": "./dist/presets/dark-pro.css",
    "./styles/presets/light": "./dist/presets/light.css",
    "./styles/presets/high-contrast": "./dist/presets/high-contrast.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist && cp src/tokens.css dist/ && sed 's|@import .\\.\\./tokens\\.css.|@import \"./tokens.css\";|' src/styles/structure.css > dist/structure.css && mkdir -p dist/presets && cp src/presets/*.css dist/presets/",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@webpacked-timeline/core": ">=1.0.0-beta.1",
    "@webpacked-timeline/react": ">=1.0.0-beta.1",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@webpacked-timeline/core": "workspace:*",
    "@webpacked-timeline/react": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "keywords": [
    "timeline",
    "react",
    "nle",
    "davinci",
    "video-editor",
    "ui",
    "components",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/webpacked/timeline",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/webpacked/timeline/blob/main/packages/ui/README.md",
  "dependencies": {
    "lucide-react": "^1.21.0"
  }
}
