{
  "name": "@timelinx/react",
  "version": "1.0.0-beta.1",
  "description": "React adapter for @timelinx/core. Hooks, context, and tool routing for building timeline editors.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@timelinx/core": ">=1.0.0-beta.1",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@timelinx/core": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.1.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^2.1.8"
  },
  "keywords": ["timeline", "react", "nle", "video-editor", "hooks", "typescript"],
  "author": "Timeline Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/maanaaasss/timelinx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maanaaasss/timelinx",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/maanaaasss/timelinx/blob/main/packages/react/README.md",
  "publishConfig": {
    "access": "public"
  }
}
